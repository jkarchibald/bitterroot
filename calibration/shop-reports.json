  "schemaVersion": 3,
  "note": "Append-only fly-shop calibration log. One record = one shop report for one river on one day. Never overwrite; each scrape appends. PULL-AND-PARK: the scraper collects ALL rivers a shop offers, but off-gauge rivers (no gauge in this app yet) are parked with gauges:[] and active:false -- collected + dated from day one so future drainages (e.g. Clark Fork incl. Rock Creek) start with banked history. Activating later = fill gauges[] + flip active:true; no re-scrape, no reformat. Active queries filter active:true. Fly table primary; tip prose cross-checks. Ratings normalized to 0-10 (rating.value0to10). Shop water temp is SOFT cross-check only -- our gauges authoritative. nameCanonical (alias layer, build-step 1) drives cross-shop agreement counting.",
  "schema": {
    "id": "string, stable per report+date",
    "scrapedAt": "ISO datetime -- when WE pulled it",
    "reportDate": "YYYY-MM-DD -- date the shop stamped",
    "source": "platform (Orvis, Grizzly Hackle, Fly Fish Food, Blackfoot-own)",
    "reporter": "the actual guide/shop author -- weighting is by this, not source",
    "url": "string",
    "river": "human name",
    "gauges": "array of our gauge ids this report covers (crosswalk to the app)",
    "rating": {
      "raw": "as shown ('80%'|'Good')",
      "scale": "'pct'|'orvis-5step'",
      "value0to10": "number, our normalized rating (80% -> 8, Good -> 7.5)"
    },
    "shopWaterTempF": "number|null -- SOFT cross-check, not authoritative",
    "hatches": "array of strings",
    "bestTime": "string|null",
    "technique": "string|null",
    "flies": "array of { rank, nameRaw, nameCanonical, type(dry|nymph|dd|streamer), colors[], sizes }",
    "tip": "guide prose",
    "tipFlies": "array of fly names pulled from the tip prose (cross-check)",
    "drainage": "drainage key (e.g. 'bitterroot','clark-fork') -- groups rivers for future multi-drainage expansion",
    "active": "bool -- true if this river maps to a live gauge in THIS app; false = parked (collected but not in the active dataset)"
  },
