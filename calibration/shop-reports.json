    "reporter": "the actual guide/shop author -- weighting is by this, not source",
    "url": "string",
    "river": "human name",
    "gauges": "array of our gauge ids this report covers (crosswalk to the app)",
    "rating": {
      "raw": "as shown ('80%'|'Good')",
      "scale": "'pct'|'orvis-5step'",
      "value0to10": "number, our normalized rating (80% -> 8, Good -> 7.5)"
    },
    "shopWaterTempF": "number|null -- SOFT cross-check, not authoritative",
    "hatches": "array of strings",
    "bestTime": "string|null",
    "technique": "string|null",
    "flies": "array of { rank, nameRaw, nameCanonical, type(dry|nymph|dd|streamer), colors[], sizes }",
    "tip": "guide prose",
    "tipFlies": "array of fly names pulled from the tip prose (cross-check)",
    "drainage": "drainage key (e.g. 'bitterroot','clark-fork') -- groups rivers for future multi-drainage expansion",
    "active": "bool -- true if this river maps to a live gauge in THIS app; false = parked (collected but not in the active dataset)"
  },
